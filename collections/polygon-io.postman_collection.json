  "info": {
    "_postman_id": "deda507b-2ffb-4608-a70d-ae8a93adb70b",
    "name": "Polygon.io REST API (Stocks)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Polygon.io (rebranded as Massive in early 2026) exposes real-time\nand historical US equity market data via a REST API at\n`https://api.polygon.io`. This specification captures a\nrepresentative subset of the Stocks API: aggregate bars and ticker\nreference. Authentication uses an API key, sent either as the\n`apiKey` query parameter or as `Authorization: Bearer <apiKey>`.\n\n\nContact Support:\n Name: Polygon.io / Massive Documentation",
      "type": "text/plain"
    }
  }
